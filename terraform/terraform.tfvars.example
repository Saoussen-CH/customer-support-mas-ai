# ==============================================================================
# terraform.tfvars.example
# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.
# ==============================================================================

# Required
project_id          = "your-gcp-project-id"
staging_bucket_name = "your-project-id-staging"   # must be globally unique
github_owner        = "your-github-username-or-org"

# Optional — defaults shown
# google_managed_sas_exist    = false              # Set true after first: make deploy-agent-engine
# github_connected             = false              # Set true after creating 2nd gen connection
# cloudbuild_connection_name   = "github-connection"              # Name given to the 2nd gen host connection
# cloudbuild_repo_name         = "Saoussen-CH-customer-support-mas-ai"  # From: gcloud builds repositories list --connection=<name> --region=<region>
# region                = "us-central1"
# firestore_location    = "nam5"            # nam5=US multi-region, eur3=Europe multi-region
# firestore_database_id = "customer-support-db"
# ar_repo_name          = "customer-support"
# cloud_run_service_name = "customer-support-app"
# github_repo           = "customer-support-mas-ai"
# model_armor_enabled   = true
# model_armor_floor_mode = "INSPECT_AND_BLOCK"  # or "INSPECT_ONLY"
