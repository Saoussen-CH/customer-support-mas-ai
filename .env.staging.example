# STAGING environment — copy to .env.staging (gitignored)
# Activate: cp .env.staging .env  OR  make switch-env ENV=staging

GOOGLE_CLOUD_PROJECT=css-mas-staging
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_STORAGE_BUCKET=gs://css-mas-staging-staging
AGENT_ENGINE_DISPLAY_NAME=customer-support-multiagent
AGENT_ENGINE_RESOURCE_NAME=   # fill after: make deploy-agent-engine
GOOGLE_GENAI_USE_VERTEXAI=1
FIRESTORE_DATABASE=customer-support-db
MODEL_ARMOR_ENABLED=true
MODEL_ARMOR_TEMPLATE_ID=      # fill after: make infra-up ENV=staging (terraform output)
MODEL_ARMOR_MODE=INSPECT_AND_BLOCK
