# DEV environment — copy to .env.dev (gitignored)
# Activate: cp .env.dev .env  OR  make switch-env ENV=dev

GOOGLE_CLOUD_PROJECT=css-mas-dev
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_STORAGE_BUCKET=gs://css-mas-dev-staging
AGENT_ENGINE_DISPLAY_NAME=customer-support-multiagent
AGENT_ENGINE_RESOURCE_NAME=   # fill after: make deploy-agent-engine
GOOGLE_GENAI_USE_VERTEXAI=1
FIRESTORE_DATABASE=customer-support-db
MODEL_ARMOR_ENABLED=true
MODEL_ARMOR_TEMPLATE_ID=      # fill after: make infra-up ENV=dev (terraform output)
MODEL_ARMOR_MODE=INSPECT_ONLY # dev: log only, don't block
ENV=development               # use gemini-2.5-flash for root agent (avoids 429 on low-quota dev projects)
